<Window x:Class="W2G_desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="W2G Desktop"
        Height="450"
        Width="800"
        Loaded="MainWindow_Loaded">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barre de navigation -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left">

            <Button x:Name="UsersButton"
                    Content="Utilisateurs"
                    Width="160"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="UsersButton_Click"/>

            <Button x:Name="CustomersButton"
                    Content="Liste des clients"
                    Width="160"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="CustomersButton_Click"/>

            <Button x:Name="ReservationsButton"
                    Content="Réservations"
                    Width="160"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="ReservationsButton_Click"/>

            <Button x:Name="OffersButton" 
                    Content="Offres"
                    Width="160"
                    Height="30"
                    Margin="0,0,10,0"
                Click="OffersButton_Click"/>

            <Button x:Name="BaysButton"
                    Content="Baies"
                    Width="150"
                    Height="30"
                    Margin="0,0,0,0"
                    Click="BaysButton_Click"/>

        </StackPanel>

        <Frame x:Name="MainFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"/>

    </Grid>

</Window>