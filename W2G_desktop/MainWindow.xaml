<mah:MetroWindow x:Class="W2G_desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="W2G Desktop"
        Height="600"
        Width="1100"
        Loaded="MainWindow_Loaded">

    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- STYLE SIDEBAR -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E3A5E"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3F4E78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <DockPanel LastChildFill="True">

        <!-- SIDEBAR -->
        <StackPanel DockPanel.Dock="Left"
                    Width="220"
                    Background="#1F2A44"
                    Visibility="{Binding IsUserLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}">

            <!-- LOGO -->
            <TextBlock Text="W2G"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="15"/>

            <!-- NAVIGATION -->

            <Button x:Name="UsersButton"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="UsersButton_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Account" Width="20" Margin="0,0,10,0"/>
                    <TextBlock Text="Utilisateurs"/>
                </StackPanel>
            </Button>

            <Button x:Name="CustomersButton"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="CustomersButton_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="AccountGroup" Width="20" Margin="0,0,10,0"/>
                    <TextBlock Text="Clients"/>
                </StackPanel>
            </Button>

            <Button x:Name="ReservationsButton"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="ReservationsButton_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Calendar" Width="20" Margin="0,0,10,0"/>
                    <TextBlock Text="Réservations"/>
                </StackPanel>
            </Button>

            <Button x:Name="OffersButton"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="OffersButton_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Briefcase" Width="20" Margin="0,0,10,0"/>
                    <TextBlock Text="Offres"/>
                </StackPanel>
            </Button>

            <Button x:Name="BaysButton"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="BaysButton_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Server" Width="20" Margin="0,0,10,0"/>
                    <TextBlock Text="Baies"/>
                </StackPanel>
            </Button>

            <Button x:Name="Interventions"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="Interventions_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Tools" Width="20" Margin="0,0,10,0"/>
                    <TextBlock Text="Interventions"/>
                </StackPanel>
            </Button>

        </StackPanel>

        <!-- CONTENU -->
        <DockPanel LastChildFill="True" Background="#F5F7FA">

            <!-- HEADER -->
            <Grid DockPanel.Dock="Top" Height="60" Background="White">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="WorkTogether Data Solutions"
                           FontWeight="Bold"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="15,0"/>

                <!-- USER PANEL -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="0,0,15,0"
                            x:Name="UserPanel"
                            Visibility="Collapsed">

                    <TextBlock x:Name="CurrentUserTextBlock"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"
                               FontWeight="SemiBold"/>

                    <!-- LOGOUT -->
                    <Button x:Name="LogoutButton"
                            Click="LogoutButton_Click"
                            Padding="10,5"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand">

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Logout" Width="18" Margin="0,0,5,0"/>
                            <TextBlock Text="Déconnexion"/>
                        </StackPanel>

                    </Button>

                </StackPanel>
            </Grid>

            <!-- FRAME -->
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Margin="10"/>
        </DockPanel>
    </DockPanel>
</mah:MetroWindow>