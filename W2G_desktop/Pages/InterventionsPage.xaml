<Page x:Class="W2G_desktop.Pages.InterventionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Interventions">

    <Grid Background="#EEF1F5" Margin="20">

        <!-- CARD -->
        <Border Padding="20"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <!-- HEADER -->
                <TextBlock Text="Liste des interventions"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- DATAGRID -->
                <DataGrid x:Name="InterventionsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MaxHeight="400"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">

                    <!-- STYLE HEADER -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- STYLE ROW -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Height" Value="35"/>
                            <Style.Triggers>
                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EDF2F7"/>
                                </Trigger>
                                <!-- Sélection -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLONNES -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Technicien" Binding="{Binding Technician}" Width="150"/>
                        <DataGridTextColumn Header="Baie" Binding="{Binding BayLabel}" Width="100"/>
                        <DataGridTextColumn Header="Unité" Binding="{Binding UnitLabel}" Width="100"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding TypeIntervention}" Width="120"/>
                        <DataGridTextColumn Header="Début" Binding="{Binding DateDeb}" Width="150"/>
                        <DataGridTextColumn Header="Fin" Binding="{Binding DateFin}" Width="150"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>

                </DataGrid>

            </StackPanel>
        </Border>
    </Grid>
</Page>