<Page x:Class="W2G_desktop.Pages.InterventionsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Interventions">
    <Grid Margin="20">
        <DataGrid x:Name="InterventionsGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Technicien" Binding="{Binding Technician}" Width="150"/>
                <DataGridTextColumn Header="Baie" Binding="{Binding BayLabel}" Width="100"/>
                <DataGridTextColumn Header="Unité" Binding="{Binding UnitLabel}" Width="100"/>
                <DataGridTextColumn Header="Type" Binding="{Binding TypeIntervention}" Width="120"/>
                <DataGridTextColumn Header="Début" Binding="{Binding DateDeb}" Width="150"/>
                <DataGridTextColumn Header="Fin" Binding="{Binding DateFin}" Width="150"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>