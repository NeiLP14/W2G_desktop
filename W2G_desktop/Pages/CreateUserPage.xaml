<Page x:Class="W2G_desktop.Pages.CreateUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Créer un utilisateur">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Email -->
        <TextBlock Text="Email :" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="EmailTextBox"
                 Grid.Row="0"
                 Grid.Column="1"
                 Width="250"
                 Margin="0,5"/>

        <!-- Username -->
        <TextBlock Text="Nom d'utilisateur :" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="UsernameTextBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 Width="250"
                 Margin="0,5"/>

        <!-- Password -->
        <TextBlock Text="Mot de passe :" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <PasswordBox x:Name="PasswordBox"
                     Grid.Row="2"
                     Grid.Column="1"
                     Width="250"
                     Margin="0,5"/>

        <!-- Role -->
        <TextBlock Text="Rôle :" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="RoleComboBox"
                  Grid.Row="3"
                  Grid.Column="1"
                  Width="250"
                  Margin="0,5">

            <ComboBoxItem Content="ROLE_ADMIN"/>
            <ComboBoxItem Content="ROLE_TECHNICIAN"/>
            <ComboBoxItem Content="ROLE_ACCOUNTANT"/>

        </ComboBox>

        <!-- Error -->
        <TextBlock x:Name="ErrorTextBlock"
                   Grid.Row="4"
                   Grid.ColumnSpan="2"
                   Foreground="Red"
                   Margin="0,10,0,0"/>

        <!-- Button -->
        <Button Content="Créer"
                Grid.Row="5"
                Grid.Column="1"
                Width="120"
                Height="30"
                Margin="0,15,0,0"
                HorizontalAlignment="Left"
                Click="CreateButton_Click"/>

    </Grid>

</Page>