<Page x:Class="W2G_desktop.Pages.CreateUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Créer un utilisateur">

    <Grid Background="#EEF1F5">

        <!-- CARD -->
        <Border Width="400"
                Padding="25"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <!-- HEADER -->
                <TextBlock Text="Créer un utilisateur"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <!-- EMAIL -->
                <TextBlock Text="Email" FontWeight="SemiBold"/>
                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="Email" Margin="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="EmailTextBox"
                             Grid.Column="1"
                             Height="35"
                             VerticalContentAlignment="Center"
                             mah:TextBoxHelper.Watermark="Ex: utilisateur@email.com"/>
                </Grid>

                <!-- USERNAME -->
                <TextBlock Text="Nom d'utilisateur" FontWeight="SemiBold"/>
                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="Account" Margin="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="UsernameTextBox"
                             Grid.Column="1"
                             Height="35"
                             VerticalContentAlignment="Center"
                             mah:TextBoxHelper.Watermark="Ex: john_doe"/>
                </Grid>

                <!-- PASSWORD -->
                <TextBlock Text="Mot de passe" FontWeight="SemiBold"/>
                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="Lock" Margin="5" VerticalAlignment="Center"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Grid.Column="1"
                                 Height="35"
                                 VerticalContentAlignment="Center"
                                 mah:TextBoxHelper.Watermark="Votre mot de passe"/>
                </Grid>

                <!-- ROLE -->
                <TextBlock Text="Rôle" FontWeight="SemiBold"/>
                <Grid Margin="0,5,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="ShieldAccount" Margin="5" VerticalAlignment="Center"/>
                    <ComboBox x:Name="RoleComboBox"
                              Grid.Column="1"
                              Height="35">
                        <ComboBoxItem Content="ROLE_ADMIN"/>
                        <ComboBoxItem Content="ROLE_TECHNICIAN"/>
                        <ComboBoxItem Content="ROLE_ACCOUNTANT"/>
                    </ComboBox>
                </Grid>

                <!-- ERREUR -->
                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#E74C3C"
                           TextAlignment="Center"
                           Margin="0,0,0,15"
                           TextWrapping="Wrap"/>

                <!-- BOUTON -->
                <Button Content="Créer l'utilisateur"
                        Height="40"
                        FontWeight="Bold"
                        Style="{DynamicResource MahApps.Metro.Styles.Button.Accent}"
                        Click="CreateButton_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>