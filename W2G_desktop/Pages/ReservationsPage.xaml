<Page x:Class="W2G_desktop.Pages.ReservationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Réservations">

    <Grid Margin="10">

        <DataGrid x:Name="ReservationsGrid"
                  IsReadOnly="True"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>

                <DataGridTextColumn Header="Client" Binding="{Binding Username}" Width="250"/>

                <DataGridTextColumn Header="Offre" Binding="{Binding Offre}" Width="150"/>

                <DataGridTextColumn Header="Début" Binding="{Binding DateDeb}" Width="150"/>

                <DataGridTextColumn Header="Fin" Binding="{Binding DateFin}" Width="150"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Page>