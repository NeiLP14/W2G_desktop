<Page x:Class="W2G_desktop.Pages.OffresPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Offres">

    <Grid Background="#EEF1F5">

        <!-- CARD -->
        <Border Margin="20"
                Padding="20"
                Background="White"
                CornerRadius="10">

            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <TextBlock Text="Gestion des offres"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- DATAGRID -->
                <DataGrid x:Name="OffersGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="OffersGrid_SelectionChanged"
                          Margin="0,0,0,15"
                          RowHeight="35"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">

                    <!-- STYLE HEADER -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- STYLE LIGNES (FIX HOVER BUG) -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>

                            <Style.Triggers>

                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EDF2F7"/>
                                </Trigger>

                                <!-- Sélection -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>

                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLONNES -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*"/>
                        <DataGridTextColumn Header="Unités" Binding="{Binding NbUnit}" Width="100"/>
                        <DataGridTextColumn Header="Prix (€)" Binding="{Binding Price}" Width="120"/>
                        <DataGridTextColumn Header="Réduction (%)" Binding="{Binding Reduction}" Width="130"/>
                        <DataGridTextColumn Header="Réservations" Binding="{Binding NbReservations}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ACTIONS -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">

                    <!-- CREATE -->
                    <Button x:Name="CreateOfferButton"
                            Height="40"
                            Margin="0,0,10,0"
                            Padding="15,5"
                            Style="{DynamicResource MahApps.Metro.Styles.Button.Accent}"
                            Click="CreateOfferButton_Click">

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="18" Margin="0,0,5,0"/>
                            <TextBlock Text="Créer"/>
                        </StackPanel>
                    </Button>

                    <!-- EDIT -->
                    <Button x:Name="EditOfferButton"
                            Height="40"
                            Margin="0,0,10,0"
                            Padding="15,5"
                            IsEnabled="False"
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            Click="EditOfferButton_Click">

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Pencil" Width="18" Margin="0,0,5,0"/>
                            <TextBlock Text="Modifier"/>
                        </StackPanel>
                    </Button>

                    <!-- DELETE -->
                    <Button x:Name="DeleteOfferButton"
                            Height="40"
                            Padding="15,5"
                            IsEnabled="False"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Click="DeleteOfferButton_Click">

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Delete" Width="18" Margin="0,0,5,0"/>
                            <TextBlock Text="Supprimer"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Page>