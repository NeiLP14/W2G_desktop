<Page x:Class="W2G_desktop.Pages.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Liste des utilisateurs">

    <Grid Background="#EEF1F5" Margin="20">

        <!-- CARD -->
        <Border Padding="20"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <!-- HEADER -->
                <TextBlock Text="Liste des utilisateurs"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- DATAGRID -->
                <DataGrid x:Name="UsersGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          Margin="0,0,0,15"
                          RowHeight="35"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          SelectionChanged="UsersGrid_SelectionChanged">

                    <!-- STYLE HEADER -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- STYLE LIGNES (PAS DE HOVER QUI FAIT DISPARAÎTRE) -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLONNES -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                        <DataGridTextColumn Header="Nom d'utilisateur" Binding="{Binding Username}" Width="150"/>
                        <DataGridTextColumn Header="Rôle" Binding="{Binding Role}" Width="150"/>
                        <DataGridTextColumn Header="Discr" Binding="{Binding Discr}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- BOUTONS -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

                    <!-- CREATE -->
                    <Button x:Name="CreateUserButton"
                            Height="40"
                            Margin="0,0,10,0"
                            Padding="15,5"
                            Style="{DynamicResource MahApps.Metro.Styles.Button.Accent}"
                            Click="CreateUserButton_Click">

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="18" Margin="0,0,5,0"/>
                            <TextBlock Text="Créer"/>
                        </StackPanel>
                    </Button>

                    <!-- EDIT -->
                    <Button x:Name="EditUserButton"
                            Height="40"
                            Margin="0,0,10,0"
                            Padding="15,5"
                            IsEnabled="False"
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            Click="EditUserButton_Click">

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Pencil" Width="18" Margin="0,0,5,0"/>
                            <TextBlock Text="Modifier"/>
                        </StackPanel>
                    </Button>

                    <!-- DELETE -->
                    <Button x:Name="DeleteUserButton"
                            Height="40"
                            Padding="15,5"
                            IsEnabled="False"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Click="DeleteUserButton_Click">

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Delete" Width="18" Margin="0,0,5,0"/>
                            <TextBlock Text="Supprimer"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>