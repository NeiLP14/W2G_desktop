<Page x:Class="W2G_desktop.Pages.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Liste des utilisateurs">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tableau des utilisateurs -->
        <DataGrid x:Name="UsersGrid"
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  Margin="0,0,0,10"
                  SelectionChanged="UsersGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                <DataGridTextColumn Header="Nom d'utilisateur" Binding="{Binding Username}" Width="150"/>
                <DataGridTextColumn Header="Rôle" Binding="{Binding Role}" Width="150"/>
                <DataGridTextColumn Header="Discr" Binding="{Binding Discr}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Boutons en dessous -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button x:Name="CreateUserButton"
                    Content="Créer un utilisateur"
                    Width="160"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="CreateUserButton_Click"/>

            <Button x:Name="EditUserButton"
                    Content="Modifier"
                    Width="160"
                    Height="30"
                    IsEnabled="False"
                    Margin="0,0,10,0"
                    Click="EditUserButton_Click"/>

            <Button x:Name="DeleteUserButton"
                    Content="Supprimer"
                    Width="160"
                    Height="30"
                    IsEnabled="False"
                    Margin="0,0,0,0"
                    Click="DeleteUserButton_Click"/>
        </StackPanel>
    </Grid>
</Page>