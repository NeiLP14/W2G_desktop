<Page x:Class="W2G_desktop.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Connexion"
      KeyDown="Page_KeyDown">

    <Grid Background="#EEF1F5">

        <!-- Carte Login -->
        <Border Width="400"
                Padding="30"
                CornerRadius="12"
                Background="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <!-- Ombre -->
            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="3"
                                  Opacity="0.25"/>
            </Border.Effect>

            <StackPanel>

                <!-- Logo / Titre -->
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="W2G"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="WorkTogether Data Solutions"
                               FontSize="12"
                               Foreground="Gray"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- EMAIL -->
                <TextBlock Text="Adresse email"
                           FontWeight="SemiBold"/>

                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="EmailOutline"
                                                VerticalAlignment="Center"
                                                Margin="5"
                                                Width="20"
                                                Height="20"/>

                    <TextBox x:Name="EmailTextBox"
                             Grid.Column="1"
                             Height="35"
                             VerticalContentAlignment="Center"
                             TextChanged="InputChanged"
                             mah:TextBoxHelper.Watermark="admin@mail.com"
                             mah:TextBoxHelper.ClearTextButton="True"/>
                </Grid>

                <!-- PASSWORD -->
                <TextBlock Text="Mot de passe"
                           FontWeight="SemiBold"/>

                <Grid Margin="0,5,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="LockOutline"
                                                VerticalAlignment="Center"
                                                Margin="5"
                                                Width="20"
                                                Height="20"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Grid.Column="1"
                                 Height="35"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="InputChanged"/>
                </Grid>

                <!-- BOUTON LOGIN -->
                <Button x:Name="LoginButton"
                        Content="Se connecter"
                        Height="40"
                        FontWeight="Bold"
                        IsEnabled="False"
                        Style="{DynamicResource MahApps.Metro.Styles.Button.Accent}"
                        Click="LoginButton_Click"/>

                <!-- MESSAGE ERREUR -->
                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#E74C3C"
                           Margin="0,15,0,0"
                           TextAlignment="Center"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>