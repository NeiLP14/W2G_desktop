<Page x:Class="W2G_desktop.Pages.BaysPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Baies">

    <Grid Background="#EEF1F5" Margin="20">

        <!-- CARD -->
        <Border Padding="20"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <!-- HEADER -->
                <TextBlock Text="Gestion des baies"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- DATAGRID -->
                <DataGrid x:Name="BaysGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="None"
                          RowHeight="35"
                          BorderThickness="0"
                          MaxHeight="400"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          SelectionChanged="BaysGrid_SelectionChanged">

                    <!-- STYLE HEADER -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- STYLE ROWS -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EDF2F7"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLONNES -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*"/>
                        <DataGridTextColumn Header="Taille" Binding="{Binding Size}" Width="120"/>
                    </DataGrid.Columns>

                </DataGrid>

                <!-- BOUTONS -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">

                    <!-- Créer une baie -->
                    <Button x:Name="CreateBayButton"
                            Content="💾 Créer"
                            Height="40"
                            Width="160"
                            Margin="0,0,10,0"
                            FontWeight="Bold"
                            Style="{DynamicResource MahApps.Metro.Styles.Button.Accent}"
                            Visibility="Collapsed"
                            Click="CreateBayButton_Click"/>

                    <!-- Modifier -->
                    <Button x:Name="EditBayButton"
                            Content="✏️ Modifier"
                            Height="40"
                            Width="160"
                            Margin="0,0,10,0"
                            FontWeight="Bold"
                            Style="{DynamicResource MahApps.Metro.Styles.Button.Flat}"
                            IsEnabled="False"
                            Click="EditBayButton_Click"/>

                    <!-- Voir les unités en vert -->
                    <Button x:Name="ViewUnitsButton"
                            Content="📦 Voir les unités"
                            Height="40"
                            Width="160"
                            FontWeight="Bold"
                            Style="{DynamicResource MahApps.Metro.Styles.Button.Success}"
                            IsEnabled="False"
                            Click="VoirUnits_Click"/>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>