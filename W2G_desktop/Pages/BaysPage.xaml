<Page x:Class="W2G_desktop.Pages.BaysPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Baies">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tableau des baies -->
        <DataGrid x:Name="BaysGrid"
                  Grid.Row="0"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  SelectionChanged="BaysGrid_SelectionChanged"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="150"/>
                <DataGridTextColumn Header="Taille" Binding="{Binding Size}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Boutons sous le tableau -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left">
            <!-- Bouton créer baie -->
            <Button x:Name="CreateBayButton"
                    Content="Créer une baie"
                    Width="150"
                    Height="30"
                    Visibility="Collapsed"
                    Margin="0,0,10,0"
                    Click="CreateBayButton_Click"/>

            <!-- Bouton modifier baie -->
            <Button x:Name="EditBayButton"
                    Content="Modifier"
                    Width="150"
                    Height="30"
                    IsEnabled="False"
                    Click="EditBayButton_Click"/>
        </StackPanel>
    </Grid>
</Page>