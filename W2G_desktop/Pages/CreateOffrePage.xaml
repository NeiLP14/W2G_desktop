<Page x:Class="W2G_desktop.Pages.CreateOffrePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Créer une offre">

    <Grid Background="#EEF1F5">

        <!-- CARD -->
        <Border Width="400"
                Padding="25"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <!-- HEADER -->
                <TextBlock Text="Créer une offre"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <!-- LABEL -->
                <TextBlock Text="Label" FontWeight="SemiBold"/>

                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="Tag" Margin="5" VerticalAlignment="Center"/>

                    <TextBox x:Name="LabelTextBox"
                             Grid.Column="1"
                             Height="35"
                             VerticalContentAlignment="Center"
                             mah:TextBoxHelper.Watermark="Nom de l'offre"/>
                </Grid>

                <!-- UNITES -->
                <TextBlock Text="Unités" FontWeight="SemiBold"/>

                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="Counter" Margin="5" VerticalAlignment="Center"/>

                    <TextBox x:Name="NbUnitTextBox"
                             Grid.Column="1"
                             Height="35"
                             VerticalContentAlignment="Center"
                             mah:TextBoxHelper.Watermark="Ex: 10"/>
                </Grid>

                <!-- PRIX -->
                <TextBlock Text="Prix (€)" FontWeight="SemiBold"/>

                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="CurrencyEur" Margin="5" VerticalAlignment="Center"/>

                    <TextBox x:Name="PriceTextBox"
                             Grid.Column="1"
                             Height="35"
                             VerticalContentAlignment="Center"
                             mah:TextBoxHelper.Watermark="Ex: 99.99"/>
                </Grid>

                <!-- REDUCTION -->
                <TextBlock Text="Réduction (%)" FontWeight="SemiBold"/>

                <Grid Margin="0,5,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="Percent" Margin="5" VerticalAlignment="Center"/>

                    <TextBox x:Name="ReductionTextBox"
                             Grid.Column="1"
                             Height="35"
                             VerticalContentAlignment="Center"
                             mah:TextBoxHelper.Watermark="Ex: 10"/>
                </Grid>

                <!-- ERREUR -->
                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#E74C3C"
                           TextAlignment="Center"
                           Margin="0,0,0,15"
                           TextWrapping="Wrap"/>

                <!-- BOUTON -->
                <Button Content="Créer l'offre"
                        Height="40"
                        FontWeight="Bold"
                        Style="{DynamicResource MahApps.Metro.Styles.Button.Accent}"
                        Click="CreateButton_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>