<Page x:Class="W2G_desktop.Pages.Reporting"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:W2G_desktop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Reporting">

    <Grid>
        <DataGrid x:Name="ReportingGrid"
              AutoGenerateColumns="False"
              Margin="10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Mois" Binding="{Binding Mois}" />
                <DataGridTextColumn Header="Offre" Binding="{Binding Offre}" />
                <DataGridTextColumn Header="Réservations" Binding="{Binding NbReservations}" />
                <DataGridTextColumn Header="Chiffre d'affaire (€)" Binding="{Binding ChiffreAffaire}" />
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</Page>
