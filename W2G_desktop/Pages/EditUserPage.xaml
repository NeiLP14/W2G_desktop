<Page x:Class="W2G_desktop.Pages.EditUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Modifier un utilisateur">

    <Grid Background="#EEF1F5">

        <!-- CARD -->
        <Border Width="400"
                Padding="25"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <!-- HEADER -->
                <TextBlock Text="Modifier l'utilisateur"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <!-- EMAIL -->
                <TextBlock Text="Email" FontWeight="SemiBold"/>
                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <iconPacks:PackIconMaterial Kind="Email" Margin="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="EmailTextBox"
                             Grid.Column="1"
                             Height="35"
                             VerticalContentAlignment="Center"/>
                </Grid>

                <!-- USERNAME -->
                <TextBlock Text="Nom d'utilisateur" FontWeight="SemiBold"/>
                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <iconPacks:PackIconMaterial Kind="Account" Margin="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="UsernameTextBox"
                             Grid.Column="1"
                             Height="35"
                             VerticalContentAlignment="Center"/>
                </Grid>

                <!-- ROLE -->
                <TextBlock Text="Rôle" FontWeight="SemiBold"/>
                <Grid Margin="0,5,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <iconPacks:PackIconMaterial Kind="ShieldAccount" Margin="5" VerticalAlignment="Center"/>
                    <ComboBox x:Name="RoleComboBox"
                              Grid.Column="1"
                              Height="35"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="ROLE_ADMIN"/>
                        <ComboBoxItem Content="ROLE_TECHNICIAN"/>
                        <ComboBoxItem Content="ROLE_ACCOUNTANT"/>
                    </ComboBox>
                </Grid>

                <!-- ERREUR -->
                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="#E74C3C"
                           TextAlignment="Center"
                           Margin="0,0,0,15"
                           TextWrapping="Wrap"/>

                <!-- BOUTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">

                    <Button Content="💾 Sauvegarder"
                            Width="120"
                            Height="40"
                            FontWeight="Bold"
                            Style="{DynamicResource MahApps.Metro.Styles.Button.Accent}"
                            Click="SaveButton_Click"
                            Margin="0,0,10,0"/>

                    <Button Content="❌ Annuler"
                            Width="120"
                            Height="40"
                            FontWeight="Bold"
                            Style="{DynamicResource MahApps.Metro.Styles.Button.Flat}"
                            Click="CancelButton_Click"/>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>