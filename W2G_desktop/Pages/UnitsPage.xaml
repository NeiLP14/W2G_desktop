<Page x:Class="W2G_desktop.Pages.UnitsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Unités">

    <Grid Background="#EEF1F5" Margin="20">

        <!-- CARD -->
        <Border Padding="20"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <!-- HEADER -->
                <TextBlock x:Name="BayTitle" 
                           Text="Unités de la baie" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Margin="0,0,0,15"/>

                <!-- DATAGRID -->
                <DataGrid x:Name="UnitsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="None"
                          RowHeight="35"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          MaxHeight="400">

                    <!-- STYLE HEADER -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- STYLE ROWS -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EDF2F7"/>
                                </Trigger>
                                <!-- Sélection -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLONNES -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="100"/>
                        <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="100"/>
                        <DataGridTextColumn Header="Occupé" Binding="{Binding IsOccupied}" Width="80"/>
                        <DataGridTextColumn Header="Utilisateur" Binding="{Binding OccupantName}" Width="150"/>
                    </DataGrid.Columns>

                </DataGrid>

                <!-- BOUTONS -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <Button Content="❌ Fermer"
                            Width="120"
                            Height="40"
                            FontWeight="Bold"
                            Style="{DynamicResource MahApps.Metro.Styles.Button.Flat}"
                            Click="CancelButton_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>