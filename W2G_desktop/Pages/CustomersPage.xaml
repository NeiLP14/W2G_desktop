<Page x:Class="W2G_desktop.Pages.CustomersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Clients">

    <Grid Background="#EEF1F5" Margin="20">

        <!-- CARD -->
        <Border Padding="20"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <!-- HEADER -->
                <TextBlock Text="Liste des clients"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- DATAGRID -->
                <DataGrid x:Name="CustomersGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="None"
                          RowHeight="35"
                          BorderThickness="0">

                    <!-- STYLE HEADER -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- STYLE ROW -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Height" Value="35"/>

                            <Style.Triggers>
                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EDF2F7"/>
                                </Trigger>
                                <!-- Sélection -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLONNES -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="250"/>
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Discr}" Width="120"/>
                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="150"/>
                        <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="150"/>
                    </DataGrid.Columns>

                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</Page>