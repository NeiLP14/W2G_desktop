<Page x:Class="W2G_desktop.Pages.EditOfferPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Modifier Offre">

    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="Label"/>
            <TextBox x:Name="LabelTextBox" Width="200"/>

            <TextBlock Text="Unités" Margin="0,10,0,0"/>
            <TextBox x:Name="NbUnitTextBox" Width="200"/>

            <TextBlock Text="Prix" Margin="0,10,0,0"/>
            <TextBox x:Name="PriceTextBox" Width="200"/>

            <TextBlock Text="Réduction (%)" Margin="0,10,0,0"/>
            <TextBox x:Name="ReductionTextBox" Width="200"/>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Content="Sauvegarder" Width="120" Click="SaveButton_Click" Margin="0,0,10,0"/>
                <Button Content="Annuler" Width="120" Click="CancelButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>